# ===== Bilibili Account Cookies =====
# Login bilibili.com → F12 → Network → any request → Request Headers → Cookie
BILI_SESSDATA=
BILI_BILI_JCT=
BILI_BUVID3=
# Bot account UID (number in space page URL: space.bilibili.com/YOUR_UID)
BILI_BOT_UID=

# ===== DeepSeek API =====
DEEPSEEK_API_KEY=
# deepseek-chat (V3, fast & cheap) or deepseek-reasoner (R1, slower but stronger)
DEEPSEEK_MODEL=deepseek-chat

# ===== SMTP Email =====
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Pluto Bot

# ===== Bot Behavior =====
POLL_DM_INTERVAL=30
POLL_AT_INTERVAL=60
DAILY_LIMIT_PER_USER=10

# ===== ASR (Speech-to-Text) =====
# 字幕路径不可用时是否走 ASR 兜底
ENABLE_ASR_FALLBACK=true
# 字幕字数 < 这个值才走 ASR（因为短字幕通常是噪音/AI部分识别）
SUBTITLE_MIN_LENGTH=500
# ASR 后端：dashscope_realtime（已实现）/ dashscope_async（TBD）/ whisper（TBD）
ASR_BACKEND=dashscope_realtime
# 阿里百炼 API key（一个 key 调 paraformer 和 qwen 都行）
DASHSCOPE_API_KEY=
DASHSCOPE_ASR_MODEL=paraformer-realtime-v2
